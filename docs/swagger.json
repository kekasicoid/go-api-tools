{
    "swagger": "2.0",
    "info": {
        "description": "A collection of API tools in Go.",
        "title": "Go API Tools by Arditya Kekasi",
        "contact": {
            "name": "Official support",
            "url": "https://kekasi.co.id/en/contact/",
            "email": "arditya@kekasi.co.id"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0"
    },
    "host": "localhost:7070",
    "basePath": "/",
    "paths": {
        "/tools/instagram/download": {
            "post": {
                "description": "Extract direct download URLs for photos, videos, and reels from a public Instagram post URL. Stories are only supported when the account is public.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tools"
                ],
                "summary": "Download Instagram media",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Request ID (alphanumeric, max 50 chars)",
                        "name": "request-id",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Instagram post URL",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.InstagramDownloadRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.InstagramDownloadResponseSwag"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/model.SwaggRespError"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/model.SwaggRespError"
                        }
                    }
                }
            }
        },
        "/tools/json/format": {
            "post": {
                "description": "Format a raw JSON string into pretty JSON",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tools"
                ],
                "summary": "Format JSON data",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Request ID (alphanumeric, max 50 chars)",
                        "name": "request-id",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "JSON data to format",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.FormatJsonRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.FormatJsonResponseSwag"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/model.SwaggRespError"
                        }
                    }
                }
            }
        },
        "/tools/jwt/decode-validation": {
            "post": {
                "description": "Parse a JWT token and return its header and claims. When a secret is provided the signature is also verified and the valid field reflects the result.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tools"
                ],
                "summary": "Decode and validate JWT token",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Request ID (alphanumeric, max 50 chars)",
                        "name": "request-id",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "JWT token and optional HMAC secret",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.JWTDecodeValidationRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.JWTDecodeValidationResponseSwag"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/model.SwaggRespError"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "model.FormatJsonRequest": {
            "type": "object",
            "properties": {
                "data": {
                    "type": "string",
                    "example": "{\"name\":\"kekasi\",\"age\":25}"
                }
            }
        },
        "model.FormatJsonResponse": {
            "type": "object",
            "properties": {
                "formatted": {
                    "type": "string",
                    "example": "{\n  \"name\": \"kekasi\",\n  \"age\": 25\n}"
                }
            }
        },
        "model.FormatJsonResponseSwag": {
            "type": "object",
            "properties": {
                "response_code": {
                    "type": "string",
                    "example": "200"
                },
                "response_data": {
                    "$ref": "#/definitions/model.FormatJsonResponse"
                },
                "response_desc": {
                    "type": "string",
                    "example": "success"
                },
                "response_id": {
                    "type": "string",
                    "example": "abc-123"
                },
                "response_refnum": {
                    "type": "string",
                    "example": ""
                }
            }
        },
        "model.InstagramDownloadRequest": {
            "type": "object",
            "properties": {
                "url": {
                    "type": "string",
                    "example": "https://www.instagram.com/arditya.kekasi/p/C2uaPTYShvn/"
                }
            }
        },
        "model.InstagramDownloadResponse": {
            "type": "object",
            "properties": {
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.InstagramMediaItem"
                    }
                },
                "post_type": {
                    "type": "string",
                    "example": "reel"
                }
            }
        },
        "model.InstagramDownloadResponseSwag": {
            "type": "object",
            "properties": {
                "response_code": {
                    "type": "string",
                    "example": "200"
                },
                "response_data": {
                    "$ref": "#/definitions/model.InstagramDownloadResponse"
                },
                "response_desc": {
                    "type": "string",
                    "example": "success"
                },
                "response_id": {
                    "type": "string",
                    "example": "abc-123"
                },
                "response_refnum": {
                    "type": "string",
                    "example": ""
                }
            }
        },
        "model.InstagramMediaItem": {
            "type": "object",
            "properties": {
                "media_type": {
                    "type": "string",
                    "example": "photo"
                },
                "media_url": {
                    "type": "string",
                    "example": "https://scontent.cdninstagram.com/..."
                },
                "thumb_url": {
                    "type": "string",
                    "example": "https://scontent.cdninstagram.com/..."
                }
            }
        },
        "model.JWTDecodeValidationRequest": {
            "type": "object",
            "properties": {
                "secret": {
                    "type": "string",
                    "example": "my-secret-key"
                },
                "token": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0.dozjgNryP4J3jVmNHl0w5N_XgL0n3I9PlFUP0THsR8U"
                }
            }
        },
        "model.JWTDecodeValidationResponse": {
            "type": "object",
            "properties": {
                "claims": {
                    "type": "object",
                    "additionalProperties": true
                },
                "header": {
                    "type": "object",
                    "additionalProperties": true
                },
                "valid": {
                    "type": "boolean"
                }
            }
        },
        "model.JWTDecodeValidationResponseSwag": {
            "type": "object",
            "properties": {
                "response_code": {
                    "type": "string",
                    "example": "200"
                },
                "response_data": {
                    "$ref": "#/definitions/model.JWTDecodeValidationResponse"
                },
                "response_desc": {
                    "type": "string",
                    "example": "success"
                },
                "response_id": {
                    "type": "string",
                    "example": "abc-123"
                },
                "response_refnum": {
                    "type": "string",
                    "example": ""
                }
            }
        },
        "model.SwaggRespError": {
            "type": "object",
            "properties": {
                "response_code": {
                    "type": "string",
                    "example": "400"
                },
                "response_data": {},
                "response_desc": {
                    "type": "string",
                    "example": "data is required"
                },
                "response_id": {
                    "type": "string",
                    "example": "abc-123"
                },
                "response_refnum": {
                    "type": "string",
                    "example": ""
                }
            }
        }
    }
}